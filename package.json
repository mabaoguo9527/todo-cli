{
  "name": "@mabaoguo/todo-cli",
  "version": "1.0.0",
  "description": "A terminal TODO task manager CLI tool",
  "type": "module",
  "main": "dist/entry.js",
  "bin": {
    "todo": "bin/todo.mjs"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "start": "node bin/todo.mjs",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["cli", "todo", "task", "terminal"],
  "author": "mabaoguo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mabaoguo9527/todo-cli.git"
  },
  "homepage": "https://github.com/mabaoguo9527/todo-cli#readme",
  "bugs": {
    "url": "https://github.com/mabaoguo9527/todo-cli/issues"
  },
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.0",
    "@clack/prompts": "^0.10.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsdown": "^0.12.0",
    "typescript": "^5.8.0"
  }
}